# JWT Secret (troque por uma senha forte em produção)
JWT_SECRET=coloque_uma_senha_forte_aqui

# Porta do servidor
PORT=3001

# Modo HTTPS: http | letsencrypt | cert
HTTPS_MODE=http

# Domínio (para HTTPS e CORS)
DOMAIN=moliveiraseguranca.com.br

# CORS (origens permitidas, separadas por vírgula)
CORS_ORIGIN=http://localhost:3001,https://moliveiraseguranca.com.br,https://www.moliveiraseguranca.com.br

# Email para Let's Encrypt
LETSENCRYPT_EMAIL=contato@moliveiraseguranca.com.br

# Certificados SSL (modo cert)
SSL_KEY_PATH=
SSL_CERT_PATH=

# SMTP para notificação de leads (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha
NOTIFY_EMAIL=contato@moliveiraseguranca.com.br
